DATABASE_URL=postgresql+psycopg2://postgres:postgres@db:5432/quantfusion
REDIS_URL=redis://redis:6379/0
CORS_ORIGINS=http://localhost:3000,https://keremburakyilmaz.com
NVIDIA_API_KEY=nvapi-replace-me
# ^ from build.nvidia.com - enables /api/agent/query and analyzer regime
#   commentary. Leave as `nvapi-replace-me` to keep LLM features disabled.
NIM_MODEL=nvidia/llama-3.1-nemotron-70b-instruct
# ^ Try alternatives: meta/llama-3.3-70b-instruct,
#   mistralai/mistral-large-instruct-2407,
#   nvidia/llama-3.3-nemotron-super-49b-v1 (reasoning, more verbose).
NIM_BASE_URL=https://integrate.api.nvidia.com/v1
NIM_OCR_MODEL=nvidia/nemotron-ocr-v1
# ^ NIM vision model for earnings PDF OCR. Alternatives: nvidia/neva-22b
DEMO_PORTFOLIO_ID=00000000-0000-0000-0000-000000000000
SECRET_KEY=dev-secret-change-me
